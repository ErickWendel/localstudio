{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "files": ["playwright.config.ts"],
  "references": [
    { "path": "./packages/brand" },
    { "path": "./packages/presenter-remote" },
    { "path": "./apps/landing" },
    { "path": "./apps/editor" },
    { "path": "./apps/joystick" }
  ]
}
