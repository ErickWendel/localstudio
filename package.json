{
  "name": "localstudio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @localstudio/landing",
    "dev:landing": "npm run dev --workspace @localstudio/landing",
    "dev:editor": "npm run dev --workspace @localstudio/editor",
    "build": "npm run build --workspace @localstudio/landing && npm run build --workspace @localstudio/editor && node scripts/prepare-pages-artifacts.mjs",
    "build:landing": "npm run build --workspace @localstudio/landing",
    "build:editor": "npm run build --workspace @localstudio/editor",
    "preview": "npm run preview --workspace @localstudio/landing",
    "preview:landing": "npm run preview --workspace @localstudio/landing",
    "preview:editor": "npm run preview --workspace @localstudio/editor",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "npm run typecheck --workspace @localstudio/brand && npm run typecheck --workspace @localstudio/landing && npm run typecheck --workspace @localstudio/editor",
    "test": "npm run test --workspace @localstudio/landing && npm run test --workspace @localstudio/editor",
    "test:watch": "npm run test:watch --workspace @localstudio/editor",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
